generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// tables
model User {
  id        String           @id @default(uuid())
  name      String
  slug      String           @unique
  email     String           @unique
  password  String
  role      GlobalUserRole   @default(NORMAL)
  status    GlobalUserStatus @default(ACTIVE)
  birthdate DateTime
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime?        @updatedAt @map("updated_at")
  deletedAt DateTime?        @map("deleted_at")

  // relations
  workspaces         Workspace[]
  memberOf           WorkspaceMember[]
  productsRegisted   Product[]
  inventoryMoviments InventoryMovement[]

  // settings 
  @@map("users")
}

model Workspace {
  id        String          @id @default(uuid())
  name      String
  slug      String          @unique
  planId    Int             @map("plan_id")
  ownerId   String          @map("owner_id")
  statsus   WorkspaceStatus @default(ACTIVE)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime?       @updatedAt @map("updated_at")
  deletedAt DateTime?       @map("deleted_at")

  // relations
  owner              User                @relation(fields: [ownerId], references: [id])
  plan               Plan                @relation(fields: [planId], references: [id])
  products           Product[]
  member             WorkspaceMember[]
  inventoryMoviments InventoryMovement[]

  // settings
  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          Int               @id @default(autoincrement())
  userId      String            @map("user_id")
  workspaceId String            @map("workspace_id")
  role        UserWorkspaceRole @default(VIEWER)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime?         @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")
  expiresAt   DateTime?         @map("expires_at")

  // relations
  member    User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([userId, workspaceId])
  // settings 
  @@map("workspace_members")
}

model Product {
  id             String        @id @default(uuid())
  barcode        String        @unique
  name           String
  Purchasedprice Decimal       @map("purchased_price")
  price          Decimal
  quantity       Int
  minQuantity    Int           @map("min_quantity")
  slug           String        @unique
  cadasterId     String        @map("cadaster_id")
  workspaceId    String        @map("workspace_id")
  status         ProductStatus @default(ACTIVE)
  unit           String
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime?     @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  // relations
  workspace          Workspace           @relation(fields: [workspaceId], references: [id])
  user               User                @relation(fields: [cadasterId], references: [id])
  inventoryMovements InventoryMovement[]

  @@index([workspaceId, cadasterId])
  // settings
  @@map("products")
}

model InventoryMovement {
  id          String                   @id @default(uuid())
  workspaceId String                   @map("workspace_id")
  userId      String                   @map("user_id")
  productId   String                   @map("product_id")
  type        InventoryMovementType
  reason      InventoryMovementReason?
  note        String?
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime?                @updatedAt @map("updated_at")
  deletedAt   DateTime?                @map("deleted_at")

  // relations
  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@index([workspaceId, userId])
  // settings
  @@map("inventory_movements")
}

model Plan {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String     @unique
  color       String
  maxProducts String     @map("max_products")
  maxMembers  String     @map("max_members")
  status      PlanStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime?  @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  // relations
  workspaces Workspace[]

  @@map("plans")
}

// enum values
enum GlobalUserRole {
  ADMIN
  NORMAL
}

enum GlobalUserStatus {
  ACTIVE
  DELETED
  PADDING
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  DELETED
  PADDING
  SUSPENDED
}

enum WorkspaceStatus {
  ACTIVE
  DELETED
  PADDING
  SUSPENDED
}

enum UserWorkspaceRole {
  OWNER
  ADMIN
  MANAGER
  OPARATOR
  VIEWER
}

enum InventoryMovementType {
  IN
  OUT
  ADJUST
  DELETE
  RESTORE
}

enum InventoryMovementReason {
  VENDA
  COMPRA
  PERDA
  DEVOLUCAO
  AJUSTE
  OUTRO
}

enum PlanStatus {
  ACTIVE
  DELETED
  SUSPENDED
}
